# LLM Configuration
OPENAI_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# Security
JWT_SECRET=your-super-secret-key-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
SECURE_COOKIES=false
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Database
DATABASE_URL=postgresql://gai_user:gai_password@localhost:5432/gai_db

# Vector Database (Chroma)
CHROMA_DB_PATH=./data/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Medical Knowledge Base
PUBMED_EMAIL=your-email@example.com
PUBMED_API_KEY=optional-api-key
MEDICAL_KB_PATH=./data/medical-docs
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Speech & Audio
WHISPER_MODEL=base
TTS_ENGINE=google
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de,zh

# Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000
REACT_APP_AVATAR_NAME=GAI
REACT_APP_AVATAR_PERSONALITY=friendly,helpful,ethical

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/gai.log
DEBUG=false

# Ethics & Safety
ENABLE_CONTENT_FILTERING=true
ENABLE_AUDIT_LOGGING=true
ENABLE_MEDICAL_DISCLAIMER=true
MAX_CONVERSATION_LENGTH=50

# Feature Flags
ENABLE_VOICE_INPUT=true
ENABLE_VOICE_OUTPUT=true
ENABLE_MEDICAL_SEARCH=true
ENABLE_MCP_TOOLS=true

# Development
DEVELOPMENT_MODE=true
RELOAD_ON_CHANGE=true
